generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Severity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VulnStatus {
  TODO
  IN_PROGRESS
  DONE
  ARCHIVE
}

enum VulnSource {
  MANUAL
  IMPORT
}

/// Journal chronologique des créations et changements de statut (dashboards temporels).
enum VulnTimelineEventKind {
  CREATED
  STATUS_CHANGED
}

model ScanTemplate {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  /// Identifiant du parseur côté code (ex: pingcastle_xml, generic_csv)
  parserId    String
  /// Motif de fichier accepté (affichage / validation souple)
  fileHint    String   @default("*.xml")
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  imports ImportBatch[]
}

model Vulnerability {
  id          String       @id @default(cuid())
  title       String
  description String?
  severity    Severity     @default(MEDIUM)
  status      VulnStatus   @default(TODO)
  source      VulnSource   @default(MANUAL)
  /// Référence stable côté outil externe (ex: RiskId PingCastle)
  externalRef String?
  /// Données brutes ou champs additionnels du scan
  metadata    Json?
  /// Échéance cible (rétro-planning)
  dueAt       DateTime?
  /// Prise de connaissance de l’alerte (acquittement)
  acknowledgedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  timelineEvents VulnTimelineEvent[]

  @@index([status])
  @@index([severity])
  @@index([externalRef])
  @@index([dueAt])
  @@index([acknowledgedAt])
}

model VulnTimelineEvent {
  id              String                 @id @default(cuid())
  vulnerabilityId String
  vulnerability   Vulnerability        @relation(fields: [vulnerabilityId], references: [id], onDelete: Cascade)
  /// Instantané métier (peut différer de createdAt row pour imports rejoués).
  occurredAt      DateTime               @default(now())
  kind              VulnTimelineEventKind
  fromStatus        VulnStatus?
  toStatus          VulnStatus
  /// Gravité connue à cet instant (pour séries « ouvert par criticité »).
  severityAtEvent   Severity

  @@index([occurredAt])
  @@index([vulnerabilityId, occurredAt])
}

model ImportBatch {
  id         String   @id @default(cuid())
  templateId String
  template   ScanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fileName   String?
  /// Chemin relatif au répertoire d’archivage (REPORTS_DIR), ex. `{batchId}/1730000000_fichier.xml`
  storedPath String?
  createdAt  DateTime @default(now())
  itemCount  Int      @default(0)

  vulnerabilities Vulnerability[]
}
